{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/css/(.*)", "dest": "frontend/css/$1" },
    { "src": "/js/(.*)",  "dest": "frontend/js/$1" },
    { "src": "/manigandan.png", "dest": "frontend/manigandan.png" },
    { "src": "/resume.pdf",     "dest": "frontend/resume.pdf" },
    { "src": "/(.*)",    "dest": "frontend/index.html" }
  ]
}
